# Copy to .env.local and fill in. .env.local is gitignored — secrets never get committed.

# Supabase → Project Settings → Data API (URL) and API Keys (anon/publishable key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

